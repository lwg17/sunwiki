#!/bin/bash
work_dir=$(pwd)

if [ $# -lt 1 ]; then
  echo "Usage: $0 <python_script.py> [script arguments ...]"
  exit 1
fi

script=$1
shift

if [ ! -f "$script" ]; then
  echo "Error: '$script' not found in $work_dir"
  exit 2
fi

script_base=$(basename "$script" .py)
batch_file=$(mktemp)

{
  cat <<EOF
#!/bin/bash
#SBATCH --partition=main,main-redhat
#SBATCH --job-name=PySCF
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=16000
#SBATCH --time=72:00:00
#SBATCH --output=${script_base}_slurm.out
#SBATCH --error=${script_base}_slurm.err
#SBATCH --export=ALL
#SBATCH --mail-user=lwg17@scarletmail.rutgers.edu
#SBATCH --mail-type=END,FAIL,REQUEUE
#SBATCH --requeue

cd $(printf '%q' "$work_dir")

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1

module purge
source ~/.bashrc
conda activate pyscf

output_file="${script_base}_output_\${SLURM_JOB_ID}.txt"

echo "Running PySCF job..."
EOF

  printf '%q ' python "$script" "$@"
  printf '> "$output_file" 2>&1\n'
  printf 'hostname\n'
} > "$batch_file"

job_output=$(sbatch "$batch_file")
rm -f "$batch_file"

jobid=$(echo "$job_output" | awk '{print $4}')
echo "$job_output"
echo "Submitted PySCF job for $script. Output will go to: ${script_base}_output_${jobid}.txt"
